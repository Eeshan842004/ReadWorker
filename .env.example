# LLM - Groq (FREE)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Embeddings - Google Gemini (FREE)
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxx

# Database - pgvector
# Local Docker:
DATABASE_URL=postgresql+asyncpg://raguser:ragpass@localhost:5432/ragdb
# Cloud (Neon) — paste the connection string as-is; the app normalizes the driver + SSL:
#   DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/ragdb?sslmode=require

# Langfuse Observability (OPTIONAL — leave blank to disable, app runs fine without it)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# JWT Auth
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# App
APP_ENV=development
LOG_LEVEL=INFO

# CORS — only used when APP_ENV=production. Comma-separated allowed browser origins.
# In dev, any localhost port is allowed automatically. In prod, set your frontend URL:
#   CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
